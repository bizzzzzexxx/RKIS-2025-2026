<UserControl x:Class="LibraryApp.Views.BookEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid MaxWidth="500" Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Заголовок страницы берётся из ViewModel -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="{Binding PageTitle}"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,24" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название"
                   VerticalAlignment="Center" />
        <!-- UpdateSourceTrigger=PropertyChanged — ViewModel узнаёт об изменении
             на каждый введённый символ, а не только при потере фокуса -->
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="200" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Автор"
                   VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                 Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="200" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Год"
                   VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0"
                 Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Жанр"
                   VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,10,0,0"
                 Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />

        <CheckBox Grid.Row="5" Grid.Column="1"
                  Content="В наличии"
                  IsChecked="{Binding IsAvailable}"
                  Margin="0,14,0,0" />

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}" />
            <!-- Кнопка неактивна пока CanSave = false -->
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="8,0,0,0" />
        </StackPanel>

    </Grid>
</UserControl>