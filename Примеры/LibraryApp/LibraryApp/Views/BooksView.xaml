<UserControl x:Class="LibraryApp.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>

        <!-- Шапка -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="+ Добавить"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
                    <TextBlock Text="Каталог книг"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Панель действий — появляется только при выборе книги -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,10"
                Visibility="{Binding IsBookSelected,
                             Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="✏️ Редактировать"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Content="🗑️ Удалить"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Список книг -->
        <ListView ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  BorderThickness="0"
                  Margin="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название"  Width="220"
                                    DisplayMemberBinding="{Binding Title}" />
                    <GridViewColumn Header="Автор"     Width="160"
                                    DisplayMemberBinding="{Binding Author}" />
                    <GridViewColumn Header="Год"       Width="60"
                                    DisplayMemberBinding="{Binding Year}" />
                    <GridViewColumn Header="Жанр"      Width="120"
                                    DisplayMemberBinding="{Binding Genre}" />
                    <!-- Колонка со статусом использует DataTrigger для цвета -->
                    <GridViewColumn Header="Статус"    Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="Нет в наличии" />
                                            <Setter Property="Foreground" Value="#DC2626" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                    <Setter Property="Text"       Value="В наличии" />
                                                    <Setter Property="Foreground" Value="#16A34A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</UserControl>