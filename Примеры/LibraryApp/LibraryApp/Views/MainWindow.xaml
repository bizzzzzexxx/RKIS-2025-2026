<Window x:Class="LibraryApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LibraryApp" Width="900" Height="600"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Боковое меню навигации -->
        <Border DockPanel.Dock="Left" Width="180"
                Background="#1E293B">
            <StackPanel Margin="12,16">

                <TextBlock Text="📖 Библиотека"
                           Foreground="White"
                           FontSize="16" FontWeight="Bold"
                           Margin="4,0,0,24" />

                <!-- Команды навигации из MainWindowViewModel -->
                <Button Content="Книги"
                        Command="{Binding NavigateToBooksCommand}"
                        Style="{StaticResource NavButton}" />

                <Button Content="Авторы"
                        Command="{Binding NavigateToAuthorsCommand}"
                        Style="{StaticResource NavButton}"
                        Margin="0,4,0,0" />

            </StackPanel>
        </Border>

        <!-- ContentControl — сюда подставляются экраны.
             WPF смотрит DataType у DataTemplate в App.xaml
             и автоматически выбирает нужный UserControl -->
        <ContentControl Content="{Binding CurrentViewModel}" />

    </DockPanel>
</Window>