<UserControl x:Class="LibraryApp.Views.AuthorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="+ Добавить"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
                <TextBlock Text="Авторы"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,10"
                Visibility="{Binding IsAuthorSelected,
                             Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="✏️ Редактировать"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Content="🗑️ Удалить"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <ListView ItemsSource="{Binding Authors}"
                  SelectedItem="{Binding SelectedAuthor}"
                  BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя"      Width="150"
                                    DisplayMemberBinding="{Binding FirstName}" />
                    <GridViewColumn Header="Фамилия"  Width="150"
                                    DisplayMemberBinding="{Binding LastName}" />
                    <GridViewColumn Header="Страна"   Width="150"
                                    DisplayMemberBinding="{Binding Country}" />
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</UserControl>